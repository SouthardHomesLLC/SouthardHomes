---
import Layout from "@layouts/Layout.astro";
import Container from "@components/container.astro";
import Sectionhead from "@components/sectionhead.astro";
import { sortedGallery } from "../scripts/gallery-scripts.ts";
---

<Layout title="Gallery">
  <Container>
    <div class="bg-cover bg-center py-12 drop-shadow-sm">
      <Sectionhead>
        <Fragment slot="title">Gallery</Fragment>
        <Fragment slot="desc"></Fragment>
      </Sectionhead>
    </div>

    <div class="grid grid-cols-2 md:grid-cols-3 gap-6" id="photo-gallery">
      {sortedGallery.map((item) => (
        <a 
          href={item.largeUrl} 
          target="_blank" 
          data-pswp-width={item.width}
          data-pswp-height={item.height} 
          class="bg-black 
          rounded-lg 
          overflow-hidden 
          border-2 
          border-zinc-800 
          flex 
          flex-col 
          group 
          transition-transform 
          duration-200
          hover:scale-105
          hover:border-[#ffca28]"
        >
            <div class="aspect-video w-full overflow-hidden">
                <img 
                src={item.url} 
                alt="Southard Homes construction picture" 
                class="w-full h-full object-cover group-hover:scale-102 transition-transform duration-300"
                loading="lazy"
                />
            </div>
            
            <!-- 
            <div class="p-4 text-white mt-auto bg-black hidden md:flex justify-between items-center text-sm">
                <span>Date added: {item.date.toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' })}</span>
            </div>
            -->
        </a>
      ))}
    </div>
  </Container>
</Layout>

<script>
  //Import PhotoSwipe styles and core controller assets directly into the client runtime
  import PhotoSwipeLightbox from 'photoswipe/lightbox';
  import 'photoswipe/style.css';

  //Initialize the PhotoSwipe Lightbox with our gallery selector and configuration
  const lightbox = new PhotoSwipeLightbox({
    gallery: '#photo-gallery',
    children: 'a',
    pswpModule: () => import('photoswipe')
  });
  
  //Initialize on page run
  lightbox.init();
</script>